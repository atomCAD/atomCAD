# Network: atom_fill_halfshift

motif1 = motif { definition: """# cubic zincblende motif

PARAM PRIMARY C
PARAM SECONDARY C

SITE CORNER PRIMARY 0 0 0

SITE FACE_Z PRIMARY 0.5 0.5 0
SITE FACE_Y PRIMARY 0.5 0 0.5
SITE FACE_X PRIMARY 0 0.5 0.5

SITE INTERIOR1 SECONDARY 0.25 0.25 0.25
SITE INTERIOR2 SECONDARY 0.25 0.75 0.75
SITE INTERIOR3 SECONDARY 0.75 0.25 0.75
SITE INTERIOR4 SECONDARY 0.75 0.75 0.25

BOND INTERIOR1 ...CORNER
BOND INTERIOR1 ...FACE_Z
BOND INTERIOR1 ...FACE_Y
BOND INTERIOR1 ...FACE_X

BOND INTERIOR2 .++CORNER
BOND INTERIOR2 ..+FACE_Z
BOND INTERIOR2 .+.FACE_Y
BOND INTERIOR2 ...FACE_X

BOND INTERIOR3 +.+CORNER
BOND INTERIOR3 ..+FACE_Z
BOND INTERIOR3 ...FACE_Y
BOND INTERIOR3 +..FACE_X

BOND INTERIOR4 ++.CORNER
BOND INTERIOR4 ...FACE_Z
BOND INTERIOR4 .+.FACE_Y
BOND INTERIOR4 +..FACE_X""" }
demo_rhombicuboctahedron1 = demo_rhombicuboctahedron
parameter1 = parameter { default: demo_rhombicuboctahedron1, param_index: 0, param_name: "geometry", data_type: Blueprint, sort_order: 0, visible: true }
materialize1 = materialize { shape: parameter1, parameter_element_value_definition: "", passivate: true, rm_single: false, surf_recon: false, invert_phase: false, visible: true }
parameter2 = parameter { default: motif1, param_index: 1, param_name: "motif", data_type: Motif, sort_order: 1 }
facet_shell1 = facet_shell { max_miller_index: 2, center: (0, 0, 0), facets: [{ miller_index: (-1, 1, 1), shift: 4, symmetrize: true, visible: true }, { miller_index: (1, 0, 0), shift: 2, symmetrize: true, visible: true }, { miller_index: (1, 1, 0), shift: 3, symmetrize: true, visible: true }], visible: true }
vec31 = vec3 { x: 0.5, y: 0.5, z: 0.5, visible: true }
structure1 = structure { motif: parameter2 }
output materialize1

